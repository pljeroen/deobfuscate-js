{
  "name": "deobfuscate-js",
  "version": "0.1.0",
  "description": "From-scratch JavaScript de-obfuscation toolkit",
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "deobfuscate": "tsx src/index.ts",
    "tokenize": "tsx src/cli/tokenize.ts"
  },
  "keywords": [
    "javascript",
    "deobfuscation",
    "minification",
    "reverse-engineering"
  ],
  "author": "Jeroen",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "javascript-obfuscator": "5.3.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@babel/generator": "7.29.1",
    "@babel/parser": "7.29.0",
    "@babel/traverse": "7.29.0",
    "@babel/types": "7.29.0",
    "isolated-vm": "6.0.2"
  }
}
